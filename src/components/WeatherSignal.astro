---
import { getRegionalWeatherSafe } from "../lib/weather";

const { zones, updatedAt } = await getRegionalWeatherSafe();
---

<div class="zone-grid">
  <p class="zone-updated">Last updated: {new Date(updatedAt).toLocaleString([], { dateStyle: "medium", timeStyle: "short" })}</p>

  {Object.entries(zones).map(([, zone]) => {
    const riskLabel =
      zone.risk === "HIGH"
        ? "⚠ High disruption risk"
        : zone.risk === "MEDIUM"
          ? "⚡ Moderate risk"
          : zone.risk === "LOW"
            ? "✓ Stable conditions"
            : "No data available";

    return (
      <article class={`zone-card risk-${zone.risk.toLowerCase()}`}>
        <h3>{zone.name}</h3>
        <strong class="zone-value">{zone.label}</strong>
        <p class="zone-condition">{zone.condition}</p>
        <p class="zone-risk">{riskLabel}</p>
        {zone.error && <p class="zone-error">⚠ {zone.error}</p>}
      </article>
    );
  })}
</div>
