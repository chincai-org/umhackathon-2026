---
import "../styles/_reset.css";
import "../styles/base.css";
import NavList from "../components/NavList.astro";
// src/layouts/BaseLayout.astro
// Define the props this layout accepts
interface Props {
	title: string;
	indexOfNav: number;
}
const { title, indexOfNav } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<script src="https://cdn.jsdelivr.net/npm/htmx.org@4.0.0-beta2" integrity="sha384-v+EMKtNUAo5enmQxBqgoU/FWvVvvZHvITNzurHSl4kzvCs94wdlgHUci1lliKWKz" crossorigin="anonymous"></script>
	</head>
	<body>
		<NavList indexOfNav={indexOfNav} />
		<slot />
	</body>
</html>   
